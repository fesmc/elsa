.DS_Store
*.dSYM

# Compiler artifacts, wherever they land
*.o
*.mod
*.a
*.so
*.x

# Build output tree and figure/result dirs. Their .gitkeep files are tracked so
# the directory skeleton survives a fresh clone (the Makefile writes into
# libelsa/include and libelsa/bin without creating them).
libelsa/**
!libelsa/**/
!libelsa/**/.gitkeep
plots/**
!plots/**/
!plots/**/.gitkeep

output

# Generated by configme: the repo-root Makefile and the dependency symlink.
/Makefile
fesm-utils
.configme/config.toml

# Julia analysis environment
analysis/Manifest.toml

# Ad-hoc/debug logs
logs/

# --- Quarto documentation site (docs/) ---------------------------------------
/docs/_site/
/docs/.quarto/
